---
import { Image } from "astro:assets";
import photoperfil from "../../../../public/img/photo-perfil.webp";
---

<div class="content-presentation">
  <div class="linear-gradient-2"></div>
  <div class="linear-gradient-1"></div>

  <section class="container-persentation" id="inicio">
    <div class="container-text hero-glass">
      <h1 class="text-name">Franco Chacón</h1>

      <p class="p-profession">
        Chemical Engineer + Data Analyst
      </p>

      <div class="presentation-text">
        <p>
          I am a Chemical Engineer specialized in process analysis, industrial
          data analytics and business intelligence. My experience includes
          process simulation, mining industry analysis, Power BI dashboard
          development and engineering problem solving.
        </p>
      </div>

      <div class="cta-row">
        <a class="btn btn-primary" href="#projects">View Projects</a>
        <a class="btn btn-ghost" href="#contact">Contact</a>
      </div>
    </div>

    <div class="container-photo-profile">
      <div class="photo-perfil photo-float glass-ring">
        <picture>
          <Image
            src={photoperfil}
            alt="Foto de perfil de Franco Chacón"
          />
        </picture>
      </div>
    </div>
  </section>
</div>

<script>
  document.addEventListener(
    "click",
    (e) => {
      const link = e.target.closest('a[href^="#"]');
      if (!link) return;

      const href = link.getAttribute("href");
      if (!href || href === "#") return;

      const id = href.slice(1);
      const target = document.getElementById(id);

      if (!target) return;

      e.preventDefault();

      target.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });

      history.pushState(null, "", `#${id}`);
    },
    true
  );
</script>

<style>
  html {
    scroll-behavior: smooth;
  }

  .content-presentation {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .linear-gradient-1 {
    position: absolute;
    left: 0;
    top: 0;
    width: 500px;
    height: 520px;
    background: radial-gradient(
      at left center,
      rgba(1, 190, 150, 0.5),
      transparent,
      transparent
    );
    z-index: 0;
    pointer-events: none;
  }

  .linear-gradient-2 {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      at right center,
      rgba(1, 190, 150, 0.6),
      rgb(0, 0, 0),
      rgb(0, 0, 0)
    );
    z-index: 0;
    pointer-events: none;
  }

  .container-persentation {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 90%;
    max-width: 1355px;
    min-height: 100vh;
    margin: 0 auto;
    gap: 40px;
    z-index: 2;
  }

  .container-text {
    width: 52%;
    color: #f6f6f9;
  }

  .hero-glass {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 18px;
    padding: 22px;
  }

  .text-name {
    font-size: 34px;
    color: #01be96;
    font-weight: 800;
    letter-spacing: 1px;
    margin: 0;
  }

  .p-profession {
    font-size: 22px;
    font-weight: 800;
    margin: 6px 0 14px;
  }

  .presentation-text p {
    margin: 10px 0;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    margin-top: 18px;
    flex-wrap: wrap;
  }

  .btn {
    padding: 10px 18px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.25s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: #01be96;
    border: 1px solid #01be96;
    color: #000;
  }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1px solid rgba(1, 190, 150, 0.55);
  }

  .container-photo-profile {
    width: 48%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .photo-perfil {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.45);
  }

  .glass-ring {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .photo-perfil img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-float {
    animation: floaty 4.5s ease-in-out infinite;
  }

  @keyframes floaty {
    0%, 100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-10px);
    }
  }

  @media (max-width: 900px) {
    .container-persentation {
      flex-direction: column-reverse;
      justify-content: center;
      text-align: center;
      padding: 120px 0 40px;
    }

    .container-text,
    .container-photo-profile {
      width: 100%;
    }

    .photo-perfil {
      width: 280px;
      height: 280px;
    }

    .cta-row {
      justify-content: center;
    }
  }

  @media (max-width: 500px) {
    .linear-gradient-1 {
      display: none;
    }
  }
</style>
